# ── Indi v3 Environment Variables ──────────────────────────────────────────
# Add ALL of these in Railway → your project → Variables tab
# Never commit this file to GitHub

# ── From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# ── From Wati dashboard → Manage Account → API
WATI_API_URL=https://live-mt-server.wati.io/XXXXX
WATI_API_TOKEN=eyXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── From Shopify Admin → Apps → Develop Apps
# ⚠️ IMPORTANT for v3: App needs BOTH read_products AND write_orders permissions
SHOPIFY_STORE=indofitting.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXXXXXXXXXXXXXXXXXXX

# ── From kiriminaja.com → Dashboard → API
KIRIMINAJA_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXX
KIRIMINAJA_ORIGIN=10110  # Your Jakarta warehouse postal code

# ── From midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=Mid-server-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_ENV=production  # Change to "sandbox" for testing

# ── Railway sets this automatically
PORT=3000
